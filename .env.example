# Copy this file to .env and replace the placeholder passwords.
# Do not commit .env or any generated signing files.

# PKCS12 uses a single password. Keep these two values identical.
ANDROID_KEYSTORE_PASSWORD=CHANGE_ME_RELEASE_PASSWORD
ANDROID_KEY_PASSWORD=CHANGE_ME_RELEASE_PASSWORD
ANDROID_KEY_ALIAS=cardvault
ANDROID_DISTINGUISHED_NAME=CN=CardVault,O=CardVault,C=CN
